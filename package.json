{
  "name": "marron-town-mod",
  "version": "1.0.0",
  "description": "Marron Town — add-on RPG Minecraft Bedrock (XP vanilla, 4 arbres de compétences, boutique 12h). Architecture hexagonale, TypeScript testé.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outfile=behavior_pack/scripts/main.js --format=esm --external:@minecraft/* --target=es2022",
    "watch": "npm run build -- --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && node scripts/deploy.mjs",
    "package": "npm run build && node scripts/package.mjs"
  },
  "devDependencies": {
    "@minecraft/server": "1.19.0",
    "@minecraft/server-ui": "1.3.0",
    "archiver": "^7.0.0",
    "esbuild": "^0.21.0",
    "jimp": "^0.22.12",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
